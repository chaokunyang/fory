package basic;

message Money [id=130] {
    decimal amount = 1;
    string currency = 2;
}

union BasicValue [id=131] {
    decimal amount = 1;
    string note = 2;
    Money money = 3;
}

message BasicEnvelope [id=132] {
    Money money = 1;
    BasicValue value = 2;
    optional decimal nullable_amount = 3;
}
